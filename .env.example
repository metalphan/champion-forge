# Champion Forge — Environment Variables
#
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and must NEVER be committed.
#
# This file (.env.example) IS committed — use placeholder values only.
# Reference: https://12factor.net/config

# ─── AI Art Generation ────────────────────────────────────────────────────────
# Required only for running: npm run generate-art
# Get your key at: https://fal.ai/dashboard/keys
# Format: uuid:hash (e.g. 8b0452ed-783e-...:653198f9...)
FAL_KEY=your-fal-ai-key-here

# ─── Supabase (Phase 1 — not yet wired up) ───────────────────────────────────
# Create a project at: https://supabase.com
# Find these values at: Project Settings → API
#
# The ANON key is safe to expose in the client — it is protected by Row Level Security.
# NEVER use the service_role key in client-side code.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ─── Cron / Webhook protection (Phase 1) ─────────────────────────────────────
# Random secret used to authorize internal cron job endpoints.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# ─── App environment ──────────────────────────────────────────────────────────
# Values: development | preview | production
# Vercel sets this automatically in CI. Set locally if your code branches on it.
APP_ENV=development
